# Patterns to ignore when building packages.
# Ontologies exceeding Helm's 5 MB / Kubernetes ConfigMap 1 MB limits are excluded
# from the chart and applied separately in CI via kubectl or the bootstrap service.
bootstrap/ontologies/udl.yaml
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
