<config xmlns="urn:org:jgroups"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="urn:org:jgroups http://www.jgroups.org/schema/jgroups.xsd">

    <TCP bind_addr="match-interface:eth0"
         bind_port="${jgroups.bind_port:7800}"
         recv_buf_size="5m"
         send_buf_size="5m"/>

    <!--
        KUBE_PING discovers cluster members by querying the Kubernetes API for pods
        matching the configured namespace and labels. Requires the ServiceAccount to
        have get/list on pods and endpoints.
    -->
    <org.jgroups.protocols.kubernetes.KUBE_PING
        namespace="${jgroups.kube.namespace:ubiquia}"
        labels="${jgroups.kube.labels:component=ubiquia-core-flow-service}"/>

    <MERGE3 min_interval="5000"
            max_interval="15000"/>

    <FD_SOCK/>

    <FD_ALL timeout="10000"
            interval="2000"/>

    <VERIFY_SUSPECT timeout="1500"/>

    <BARRIER/>

    <pbcast.NAKACK2 use_mcast_xmit="false"
                   discard_delivered_msgs="true"/>

    <UNICAST3/>

    <pbcast.STABLE desired_avg_gossip="50000"
                   max_bytes="4m"/>

    <pbcast.GMS print_local_addr="true"
                join_timeout="3000"/>

    <MFC max_credits="2m"
         min_threshold="0.4"/>

    <FRAG2 frag_size="60000"/>

</config>
